# ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env.dev, .env.staging, or .env.prod and fill in the values
# DO NOT COMMIT THE ACTUAL .env FILES!

# Django
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_SETTINGS_MODULE=app.settings.dev  # override to app.settings.staging or app.settings.prod per environment

# Registry (required for staging/prod pull-only deploys)
REGISTRY_URL=registry.example.com-
APP_IMAGE_TAG=latest

# Database
POSTGRES_DB=zdravy_projekt_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432
CONN_MAX_AGE=600  # seconds; 0 disables persistent connections

# Hosts (for staging/production)
STAGING_HOST=staging.example.com
PROD_HOST=example.com
PROD_HOST_WWW=www.example.com
APP_HOST=example.com
APP_HOST_WWW=www.example.com
TRAEFIK_DOCKER_NETWORK=zdravy_public
LETSENCRYPT_EMAIL=ops@example.com

# Frontend
FRONTEND_URL=http://localhost:3000
VITE_API_URL=http://localhost:8000/api

# Email (for staging/production)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=noreply@example.com

# External observability (Sentry + Grafana)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Docker Swarm secret-file variants (recommended in production)
# DJANGO_SECRET_KEY_FILE=/run/secrets/django_secret_key
# POSTGRES_PASSWORD_FILE=/run/secrets/postgres_password
# EMAIL_HOST_PASSWORD_FILE=/run/secrets/email_host_password
# SENTRY_DSN_FILE=/run/secrets/sentry_dsn
