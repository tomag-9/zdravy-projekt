# ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env.dev, .env.staging, or .env.prod and fill in the values
# DO NOT COMMIT THE ACTUAL .env FILES!

# Django
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_SETTINGS_MODULE=app.settings.dev  # override to app.settings.staging or app.settings.prod per environment

# Registry (required for staging/prod pull-only deploys)
REGISTRY_URL=registry.example.com-

# Database
POSTGRES_DB=zdravy_projekt_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Hosts (for staging/production)
STAGING_HOST=staging.example.com
PROD_HOST=example.com
PROD_HOST_WWW=www.example.com

# Frontend
FRONTEND_URL=http://localhost:3000
VITE_API_URL=http://localhost:8000/api

# Email (for staging/production)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=noreply@example.com
