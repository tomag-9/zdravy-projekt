# Swarm deployment variables
REGISTRY_URL=ghcr.io/magi-9
APP_IMAGE_TAG=latest
APP_HOST=example.com
APP_HOST_WWW=www.example.com
TRAEFIK_DOCKER_NETWORK=zdravy_public
LETSENCRYPT_EMAIL=ops@example.com

# Let's Encrypt ACME challenge type
# For production (direct IP): use TLS challenge
ACME_TLS_CHALLENGE=true
ACME_DNS_CHALLENGE=false
# For staging (Cloudflare tunnel): use DNS challenge
# ACME_TLS_CHALLENGE=false
# ACME_DNS_CHALLENGE=true
# ACME_DNS_PROVIDER=cloudflare
# CF_API_EMAIL=cloudflare@example.com
# CF_DNS_API_TOKEN_FILE=/run/secrets/cloudflare_api_token

# External PostgreSQL (managed)
POSTGRES_DB=zdravy_projekt_db
POSTGRES_USER=zdravy_app
POSTGRES_HOST=postgres.example.internal
POSTGRES_PORT=5432

# Email
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=mailer@example.com
DEFAULT_FROM_EMAIL=noreply@example.com

# Secret values are provided via Docker secrets, not plain env vars:
# - django_secret_key
# - postgres_password
# - email_host_password
# - sentry_dsn
# - cloudflare_api_token (only for DNS challenge)
