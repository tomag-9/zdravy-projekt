{
  "dashboard": {
    "title": "Zdravy Projekt - Celery Workers",
    "tags": ["celery", "zdravy-projekt"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "30s",
    "time": {
      "from": "now-6h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Task Execution Rate",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "sum(rate(django_celery_task_status_total[5m])) by (task_name)",
            "legendFormat": "{{task_name}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "ops", "label": "Tasks/sec"},
          {"format": "short"}
        ]
      },
      {
        "id": 2,
        "title": "Task Success vs Failure Rate",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "sum(rate(django_celery_task_status_total{status=\"success\"}[5m]))",
            "legendFormat": "Success",
            "refId": "A"
          },
          {
            "expr": "sum(rate(django_celery_task_status_total{status=\"failure\"}[5m]))",
            "legendFormat": "Failure",
            "refId": "B"
          },
          {
            "expr": "sum(rate(django_celery_task_status_total{status=\"retry\"}[5m]))",
            "legendFormat": "Retry",
            "refId": "C"
          }
        ],
        "yaxes": [
          {"format": "ops", "label": "Tasks/sec"},
          {"format": "short"}
        ]
      },
      {
        "id": 3,
        "title": "Task Failure Rate (%)",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "sum(rate(django_celery_task_status_total{status=\"failure\"}[5m])) / sum(rate(django_celery_task_status_total[5m])) * 100",
            "legendFormat": "Overall Failure Rate",
            "refId": "A"
          },
          {
            "expr": "sum(rate(django_celery_task_status_total{status=\"failure\"}[5m])) by (task_name) / sum(rate(django_celery_task_status_total[5m])) by (task_name) * 100",
            "legendFormat": "{{task_name}}",
            "refId": "B"
          }
        ],
        "yaxes": [
          {"format": "percent", "label": "Failure Rate %"},
          {"format": "short"}
        ],
        "alert": {
          "name": "High Task Failure Rate",
          "conditions": [
            {
              "evaluator": {"type": "gt", "params": [10]},
              "operator": {"type": "and"},
              "query": {"params": ["A", "5m", "now"]},
              "reducer": {"type": "avg"},
              "type": "query"
            }
          ]
        }
      },
      {
        "id": 4,
        "title": "Task Duration (P95)",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(django_celery_task_duration_seconds_bucket[5m])) by (task_name, le))",
            "legendFormat": "{{task_name}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "s", "label": "Duration"},
          {"format": "short"}
        ]
      },
      {
        "id": 5,
        "title": "Active Workers",
        "type": "stat",
        "gridPos": {"h": 6, "w": 6, "x": 0, "y": 16},
        "targets": [
          {
            "expr": "django_celery_active_workers",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "textMode": "value_and_name"
        },
        "thresholds": {
          "mode": "absolute",
          "steps": [
            {"color": "red", "value": null},
            {"color": "yellow", "value": 1},
            {"color": "green", "value": 2}
          ]
        }
      },
      {
        "id": 6,
        "title": "Queue Length",
        "type": "stat",
        "gridPos": {"h": 6, "w": 6, "x": 6, "y": 16},
        "targets": [
          {
            "expr": "django_celery_queue_length",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "textMode": "value_and_name"
        },
        "thresholds": {
          "mode": "absolute",
          "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 50},
            {"color": "orange", "value": 100},
            {"color": "red", "value": 200}
          ]
        }
      },
      {
        "id": 7,
        "title": "Total Tasks Executed (24h)",
        "type": "stat",
        "gridPos": {"h": 6, "w": 6, "x": 12, "y": 16},
        "targets": [
          {
            "expr": "sum(increase(django_celery_task_status_total[24h]))",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "textMode": "value_and_name"
        }
      },
      {
        "id": 8,
        "title": "Total Failures (24h)",
        "type": "stat",
        "gridPos": {"h": 6, "w": 6, "x": 18, "y": 16},
        "targets": [
          {
            "expr": "sum(increase(django_celery_task_status_total{status=\"failure\"}[24h]))",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "textMode": "value_and_name"
        },
        "thresholds": {
          "mode": "absolute",
          "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 10},
            {"color": "red", "value": 100}
          ]
        }
      },
      {
        "id": 9,
        "title": "Queue Length Over Time",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 22},
        "targets": [
          {
            "expr": "django_celery_queue_length",
            "legendFormat": "Queue Length",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "short", "label": "Tasks in Queue"},
          {"format": "short"}
        ]
      },
      {
        "id": 10,
        "title": "Task Status Distribution",
        "type": "piechart",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 22},
        "targets": [
          {
            "expr": "sum(increase(django_celery_task_status_total[1h])) by (status)",
            "legendFormat": "{{status}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 11,
        "title": "Task Execution Details (Last Hour)",
        "type": "table",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 30},
        "targets": [
          {
            "expr": "sum(increase(django_celery_task_status_total[1h])) by (task_name, status)",
            "format": "table",
            "instant": true,
            "refId": "A"
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {"Time": true},
              "indexByName": {},
              "renameByName": {
                "task_name": "Task",
                "status": "Status",
                "Value": "Count"
              }
            }
          }
        ]
      }
    ]
  }
}
