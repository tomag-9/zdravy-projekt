# Django settings
DJANGO_SETTINGS_MODULE=app.settings.prod
DJANGO_SECRET_KEY=super-secret-key-123

# Database (Dokploy managed Postgres)
POSTGRES_DB=zdravy_projekt_prod
POSTGRES_USER=postgres_prod
POSTGRES_PASSWORD=strong-password-here
POSTGRES_HOST=postgres-zdravy-prod
POSTGRES_PORT=5432

# Redis (Dokploy managed Redis)
CELERY_BROKER_URL=redis://redis-zdravy-prod:6379/0
CELERY_RESULT_BACKEND=redis://redis-zdravy-prod:6379/0
REDIS_URL=redis://redis-zdravy-prod:6379/1

# Domain / public route
PROD_HOST=example.com
PROD_HOST_WWW=www.example.com
FRONTEND_URL=https://example.com
VITE_API_URL=https://example.com/api

# Email
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=noreply@example.com

# Push Notifications (VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_ADMIN_EMAIL=admin@example.com

# Observability
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Images
REGISTRY_USERNAME=dockerhub-username
BACKEND_IMAGE_TAG=prod
FRONTEND_IMAGE_TAG=prod
