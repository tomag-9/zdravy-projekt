# DEVELOPMENT ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env.dev for local development and fill in values.
# DO NOT COMMIT ACTUAL .env FILES!
#
# For staging/production: all variables are configured directly in the Dokploy UI.
# This file serves as documentation of what variables are needed.

# Django
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_SETTINGS_MODULE=app.settings.dev  # override per environment

# Database
POSTGRES_DB=zdravy_projekt_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# For staging/prod: MUST be Dokploy managed Postgres hostname (not 'db')
POSTGRES_HOST=postgres-zdravy
POSTGRES_PORT=5432
CONN_MAX_AGE=600  # seconds; 0 disables persistent connections

# Hosts
# Staging: your domain behind Cloudflare tunnel (e.g. zp.tomag.xyz)
STAGING_HOST=staging.example.com
PROD_HOST=example.com
PROD_HOST_WWW=www.example.com

# Frontend
FRONTEND_URL=http://localhost:3000
# For staging/prod: set as a build argument in Dokploy UI (e.g. https://zp.tomag.xyz/api)
VITE_API_URL=/api

# Email
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=noreply@example.com

# Push Notifications (VAPID)
# Generate with: python manage.py generate_vapid_keys
# VAPID_PRIVATE_KEY is a raw base64url-encoded 32-byte EC scalar (no PEM headers)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_ADMIN_EMAIL=admin@example.com

# Observability
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Deployment
# Staging deploy is triggered by GitHub Action webhook.
# Images are built in GitHub Actions and Dokploy pulls them from Docker Hub.
REGISTRY_USERNAME=dockerhub-username
# Optional rollback controls in Dokploy envs:
# Set to immutable tags like staging-<git-sha> and redeploy to rollback.
BACKEND_IMAGE_TAG=staging
FRONTEND_IMAGE_TAG=staging
