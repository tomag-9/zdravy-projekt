# Django settings
DJANGO_SETTINGS_MODULE=app.settings.staging
DJANGO_SECRET_KEY=replace-with-at-least-32-random-bytes-from-get-random-secret-key

# Database (Dokploy managed Postgres)
POSTGRES_DB=zdravy_projekt_staging
POSTGRES_USER=postgres_staging
POSTGRES_PASSWORD=strong-password-here
POSTGRES_HOST=postgres-zdravy
POSTGRES_PORT=5432

# Redis (Dokploy managed Redis)
# The app derives Celery DB 0 and cache DB 1 from this base URL.
REDIS_URL=redis://redis-zdravy:6379

# Domain
STAGING_HOST=zp.tomag.xyz
FRONTEND_URL=https://zp.tomag.xyz
VITE_API_URL=https://zp.tomag.xyz/api

# Email
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=noreply@example.com

# Push Notifications (VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_ADMIN_EMAIL=admin@example.com

# Observability
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Images
REGISTRY_USERNAME=dockerhub-username
BACKEND_IMAGE_TAG=staging
FRONTEND_IMAGE_TAG=staging

# Runtime limits / Swarm rolling update controls
BACKEND_REPLICAS=1
BACKEND_CPU_LIMIT=1.00
BACKEND_MEMORY_LIMIT=768M
BACKEND_CPU_RESERVATION=0.25
BACKEND_MEMORY_RESERVATION=256M
CELERY_REPLICAS=1
CELERY_CPU_LIMIT=1.00
CELERY_MEMORY_LIMIT=768M
CELERY_CPU_RESERVATION=0.25
CELERY_MEMORY_RESERVATION=256M
CELERY_BEAT_CPU_LIMIT=0.25
CELERY_BEAT_MEMORY_LIMIT=256M
CELERY_BEAT_CPU_RESERVATION=0.05
CELERY_BEAT_MEMORY_RESERVATION=128M
FRONTEND_REPLICAS=1
FRONTEND_CPU_LIMIT=0.50
FRONTEND_MEMORY_LIMIT=256M
FRONTEND_CPU_RESERVATION=0.10
FRONTEND_MEMORY_RESERVATION=64M
